local function Darken(color, amount)
	return Color3.new(
		math.clamp(color.R * (1 - amount), 0, 1),
		math.clamp(color.G * (1 - amount), 0, 1),
		math.clamp(color.B * (1 - amount), 0, 1)
	)
end

local function LerpColor(a, b, t)
	return Color3.new(
		a.R + (b.R - a.R) * t,
		a.G + (b.G - a.G) * t,
		a.B + (b.B - a.B) * t
	)
end

local function CopyTheme(name)
	local source = ThemePresets[name] or ThemePresets.Dark
	local copy = {}

	for key, value in pairs(source) do
		copy[key] = value
	end

	return copy
end

local Theme = CopyTheme("Dark")
Theme.Accent = Color3.fromRGB(255, 255, 255)
Theme.AccentDark = Darken(Theme.Accent, 0.25)
Theme.AccentSoft = LerpColor(Theme.Element, Theme.Accent, 0.16)

local CurrentTheme = "Dark"
local BoundObjects = {}

local function Bind(object, property, themeKey)
	table.insert(BoundObjects, {
		Object = object,
		Property = property,
		ThemeKey = themeKey,
	})

	if Theme[themeKey] ~= nil then
		object[property] = Theme[themeKey]
	end

	return object
end

local function ApplyTheme()
	for i = #BoundObjects, 1, -1 do
		local data = BoundObjects[i]

		if not data.Object or not data.Object.Parent then
			table.remove(BoundObjects, i)
		elseif Theme[data.ThemeKey] ~= nil then
			data.Object[data.Property] = Theme[data.ThemeKey]
		end
	end
end

local function SetTheme(themeName)
	if not ThemePresets[themeName] then
		return
	end

	local accent = Theme.Accent
	CurrentTheme = themeName

	local newTheme = CopyTheme(themeName)

	for key, value in pairs(newTheme) do
		Theme[key] = value
	end

	Theme.Accent = accent
	Theme.AccentDark = Darken(accent, 0.25)
	Theme.AccentSoft = LerpColor(Theme.Element, accent, 0.16)

	ApplyTheme()
end

local function SetAccent(color)
	Theme.Accent = color
	Theme.AccentDark = Darken(color, 0.25)
	Theme.AccentSoft = LerpColor(Theme.Element, color, 0.16)

	ApplyTheme()
end

--// Utility
local function Create(className, props, children)
	local object = Instance.new(className)

	for prop, value in pairs(props or {}) do
		object[prop] = value
	end

	for _, child in ipairs(children or {}) do
		child.Parent = object
	end

	return object
end

local function Corner(radius)
	return Create("UICorner", {
		CornerRadius = UDim.new(0, radius or 6)
	})
end

local function Stroke(color, thickness, transparency)
	return Create("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
		Transparency = transparency or 0
	})
end

local function Tween(object, time, props)
	local tween = TweenService:Create(
		object,
		TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		props
	)

	tween:Play()
	return tween
end

local function SafeCallback(callback, ...)
	if typeof(callback) ~= "function" then
		return
	end

	local success, err = pcall(callback, ...)
	if not success then
		warn("[dark_UI callback error]:", err)
	end
end

local function GetParent()
	local success = pcall(function()
		local test = Instance.new("Folder")
		test.Name = "dark_UI_Test"
		test.Parent = CoreGui
		test:Destroy()
	end)

	if success then
		return CoreGui
	end

	return LocalPlayer:WaitForChild("PlayerGui")
end

local function DestroyOldUI()
	pcall(function()
		for _, v in ipairs(CoreGui:GetChildren()) do
			if v.Name == "dark_UI" then
				v:Destroy()
			end
		end
	end)

	pcall(function()
		local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
		if playerGui then
			for _, v in ipairs(playerGui:GetChildren()) do
				if v.Name == "dark_UI" then
					v:Destroy()
				end
			end
		end
	end)
end

