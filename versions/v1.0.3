	local function SelectTab(tabData)
		selectedTab = tabData

		for _, data in ipairs(tabs) do
			data.Page.Visible = false

			Tween(data.Button, 0.18, {
				TextTransparency = 0.45,
				TextColor3 = Theme.SubText,
