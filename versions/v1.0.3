				Size = UDim2.new(1, -190, 1, 0),
				ZIndex = 16,
				Parent = slider,
			})

			Bind(label, "TextColor3", "Text")

			local valueLabel = Create("TextLabel", {
				Name = "value",
				Font = Enum.Font.Gotham,
				Text = tostring(value),
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Right,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -174, 0, 0),
				Size = UDim2.fromOffset(48, 32),
				ZIndex = 16,
				Parent = slider,
			})

			Bind(valueLabel, "TextColor3", "SubText")

			local track = Create("Frame", {
				Name = "track",
				Position = UDim2.new(1, -116, 0.5, -4),
				Size = UDim2.fromOffset(102, 8),
				ZIndex = 16,
				Parent = slider,
			}, {
				Corner(4),
			})

			Bind(track, "BackgroundColor3", "Container")

			local fill = Create("Frame", {
				Name = "fill",
				Size = UDim2.fromScale(0, 1),
				ZIndex = 17,
				Parent = track,
			}, {
				Corner(4),
			})

			Bind(fill, "BackgroundColor3", "Accent")

			local function SetValue(newValue, fireCallback)
				newValue = math.clamp(math.floor(newValue), min, max)

				value = newValue
				valueLabel.Text = tostring(value)

				local percent = 0
				if max ~= min then
					percent = (value - min) / (max - min)
				end

				Tween(fill, 0.08, {
					Size = UDim2.fromScale(percent, 1),
				})

				if fireCallback then
					SafeCallback(callback, value)
				end
			end

			local function UpdateFromMouse()
				local mouseX = UserInputService:GetMouseLocation().X

				local percent = math.clamp(
					(mouseX - track.AbsolutePosition.X) / track.AbsoluteSize.X,
					0,
					1
				)

				SetValue(min + ((max - min) * percent), true)
			end

			slider.MouseEnter:Connect(function()
				Tween(slider, 0.18, {
					BackgroundColor3 = Theme.ElementHover,
				})
			end)

			slider.MouseLeave:Connect(function()
				if not dragging then
					Tween(slider, 0.18, {
						BackgroundColor3 = Theme.Element,
					})
				end
			end)

			slider.MouseButton1Down:Connect(function()
				dragging = true
				Tween(slider, 0.1, {
					BackgroundColor3 = Theme.ElementDown,
				})
				UpdateFromMouse()
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false

					Tween(slider, 0.18, {
						BackgroundColor3 = Theme.Element,
					})
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					UpdateFromMouse()
				end
			end)

			SetValue(default, false)

			return {
				Instance = slider,

				Set = function(_, newValue)
					SetValue(newValue, true)
				end,

				Get = function()
					return value
				end,
			}
		end

