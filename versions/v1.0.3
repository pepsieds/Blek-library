				Bind(searchBox, "PlaceholderColor3", "SubText")
				Bind(searchBox:FindFirstChildOfClass("UIStroke"), "Color", "Stroke")
			end

			local optionHolder = Create("Frame", {
				Name = "optionHolder",
				Position = UDim2.fromOffset(6, searchEnabled and 73 or 42),
				Size = UDim2.new(1, -12, 0, 0),
				ZIndex = 16,
				Parent = dropdown,
			}, {
				Corner(6),
				Stroke(Theme.Stroke, 1, 0.35),

				Create("UIPadding", {
					PaddingLeft = UDim.new(0, 5),
					PaddingRight = UDim.new(0, 5),
					PaddingTop = UDim.new(0, 5),
					PaddingBottom = UDim.new(0, 5),
				}),

				Create("UIListLayout", {
					SortOrder = Enum.SortOrder.LayoutOrder,
					Padding = UDim.new(0, 4),
				}),
			})

			Bind(optionHolder, "BackgroundColor3", "Container")
			Bind(optionHolder:FindFirstChildOfClass("UIStroke"), "Color", "Stroke")

			local function OptionExists(option)
				for _, existing in ipairs(options) do
					if existing == option then
						return true
					end
				end

				return false
			end

			local function GetSelectedArray()
				local list = {}

				for _, option in ipairs(options) do
					if selected[option] then
						table.insert(list, option)
					end
				end

				return list
			end

			local function UpdateSelectedLabel()
				if multiSelect then
					local list = GetSelectedArray()

					if #list == 0 then
						selectedLabel.Text = "None"
					elseif #list == 1 then
						selectedLabel.Text = tostring(list[1])
					else
						selectedLabel.Text = tostring(#list) .. " selected"
					end
				else
					selectedLabel.Text = tostring(selected)
				end
			end

			local function FireCallback()
				if multiSelect then
					SafeCallback(callback, GetSelectedArray())
				else
					SafeCallback(callback, selected)
				end
			end

			local function GetVisibleCount()
				local count = 0

				for _, data in ipairs(optionButtons) do
					if data.Visible then
						count += 1
					end
				end

				return count
			end

			local function UpdateHolderSize()
				local count = GetVisibleCount()

				if count <= 0 then
					optionHolder.Size = UDim2.new(1, -12, 0, 36)
					return
				end

				local optionHeight = count * 28
				local paddingHeight = math.max(count - 1, 0) * 4
				local holderPadding = 10

				optionHolder.Size = UDim2.new(1, -12, 0, optionHeight + paddingHeight + holderPadding)
			end

			local function GetOpenHeight()
				local visibleCount = GetVisibleCount()

				if visibleCount <= 0 then
					return 42 + searchHeight + 36
				end

				local optionHeight = visibleCount * 28
				local paddingHeight = math.max(visibleCount - 1, 0) * 4
				local holderPadding = 10

				return 42 + searchHeight + optionHeight + paddingHeight + holderPadding
			end

			local function SetOpen(state)
				opened = state == true

				UpdateHolderSize()

				Tween(dropdown, 0.18, {
					Size = opened and UDim2.new(1, -14, 0, GetOpenHeight()) or UDim2.new(1, -14, 0, 36),
				})

				Tween(arrow, 0.18, {
					Rotation = opened and 180 or 0,
				})

				Tween(header, 0.18, {
					BackgroundColor3 = opened and Theme.ElementHover or Theme.Element,
				})
			end

			local function UpdateOptionVisual(optionButton, option)
				local check = optionButton:FindFirstChild("check")
				local optionText = optionButton:FindFirstChild("text")

				local isSelected

				if multiSelect then
					isSelected = selected[option] == true
				else
					isSelected = selected == option
				end

				if check then
					check.Visible = isSelected
				end

				if optionText then
					optionText.TextColor3 = isSelected and Theme.Text or Theme.SubText
				end

				Tween(optionButton, 0.12, {
					BackgroundColor3 = isSelected and Theme.AccentSoft or Theme.Element,
				})
			end

			local function RefreshVisuals()
				for _, data in ipairs(optionButtons) do
					UpdateOptionVisual(data.Button, data.Option)
				end

				UpdateSelectedLabel()
			end

			local function ApplySearchFilter()
				local query = ""

				if searchBox then
					query = string.lower(searchBox.Text)
				end

				for _, data in ipairs(optionButtons) do
					local optionText = string.lower(tostring(data.Option))
					local visibleOption = query == "" or string.find(optionText, query, 1, true) ~= nil

					data.Visible = visibleOption
					data.Button.Visible = visibleOption
					data.Button.Size = visibleOption and UDim2.new(1, 0, 0, 28) or UDim2.new(1, 0, 0, 0)
				end

				UpdateHolderSize()

				if opened then
					Tween(dropdown, 0.12, {
						Size = UDim2.new(1, -14, 0, GetOpenHeight()),
					})
				end
			end

			local function SetSelected(value, fireCallback)
				if multiSelect then
					if typeof(value) == "table" then
						table.clear(selected)

						for _, item in ipairs(value) do
							if OptionExists(item) then
								selected[item] = true
							end
						end
					else
						if OptionExists(value) then
							selected[value] = not selected[value]
						end
					end
				else
					if OptionExists(value) then
						selected = value
					else
						selected = options[1] or "None"
					end

					--// Important:
					--// Single dropdown does NOT close here anymore.
					--// It only closes when the top/header button is clicked.
				end

				RefreshVisuals()

				if fireCallback then
					FireCallback()
				end
			end

			local function ClearOptions()
				for _, data in ipairs(optionButtons) do
					data.Button:Destroy()
				end

				table.clear(optionButtons)
			end

			local function AddOption(option)
				local optionButton = Create("TextButton", {
					Name = tostring(option),
					Text = "",
					AutoButtonColor = false,
					Size = UDim2.new(1, 0, 0, 28),
					ZIndex = 18,
					Parent = optionHolder,
				}, {
					Corner(5),
				})

				Bind(optionButton, "BackgroundColor3", "Element")

				local check = Create("TextLabel", {
					Name = "check",
					Font = Enum.Font.GothamBold,
					Text = "✓",
					TextSize = 13,
					TextXAlignment = Enum.TextXAlignment.Center,
					TextYAlignment = Enum.TextYAlignment.Center,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(5, 0),
					Size = UDim2.fromOffset(20, 28),
					Visible = false,
					ZIndex = 19,
					Parent = optionButton,
				})

				Bind(check, "TextColor3", "Accent")

				local optionText = Create("TextLabel", {
					Name = "text",
					Font = Enum.Font.Gotham,
					Text = tostring(option),
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextYAlignment = Enum.TextYAlignment.Center,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(30, 0),
					Size = UDim2.new(1, -38, 1, 0),
					ZIndex = 19,
					Parent = optionButton,
				})

				Bind(optionText, "TextColor3", "SubText")

				optionButton.MouseEnter:Connect(function()
					Tween(optionButton, 0.12, {
						BackgroundColor3 = Theme.ElementHover,
					})
				end)

				optionButton.MouseLeave:Connect(function()
					UpdateOptionVisual(optionButton, option)
				end)

				optionButton.MouseButton1Click:Connect(function()
					SetSelected(option, true)
				end)

				table.insert(optionButtons, {
					Button = optionButton,
					Option = option,
					Visible = true,
				})

				UpdateOptionVisual(optionButton, option)
			end

			local function UpdateList(newOptions, newDefault)
				options = newOptions or {}

				ClearOptions()

				if multiSelect then
					local oldSelected = selected
					selected = {}

					if typeof(newDefault) == "table" then
						for _, item in ipairs(newDefault) do
							if OptionExists(item) then
								selected[item] = true
							end
						end
					else
						for _, option in ipairs(options) do
							if oldSelected[option] then
								selected[option] = true
							end
						end
					end
				else
					if newDefault ~= nil and OptionExists(newDefault) then
						selected = newDefault
					elseif OptionExists(selected) then
						selected = selected
					else
						selected = options[1] or "None"
					end
				end

				for _, option in ipairs(options) do
					AddOption(option)
				end

				ApplySearchFilter()
				RefreshVisuals()

				if opened then
					SetOpen(true)
				else
					SetOpen(false)
				end
			end

			for _, option in ipairs(options) do
				AddOption(option)
			end

			if searchBox then
				searchBox:GetPropertyChangedSignal("Text"):Connect(function()
					ApplySearchFilter()
				end)
			end

			header.MouseEnter:Connect(function()
				Tween(header, 0.14, {
					BackgroundColor3 = Theme.ElementHover,
				})
			end)

			header.MouseLeave:Connect(function()
				Tween(header, 0.14, {
					BackgroundColor3 = opened and Theme.ElementHover or Theme.Element,
				})
			end)

			header.MouseButton1Click:Connect(function()
				SetOpen(not opened)
			end)

			ApplySearchFilter()
			RefreshVisuals()

			return {
				Instance = dropdown,

				Set = function(_, value)
					SetSelected(value, true)
				end,

				Get = function()
					if multiSelect then
						return GetSelectedArray()
					end

					return selected
				end,

				Open = function()
					SetOpen(true)
				end,

				Close = function()
					SetOpen(false)
				end,

				Refresh = function(_, newOptions, newDefault)
					UpdateList(newOptions, newDefault)
				end,

				UpdateList = function(_, newOptions, newDefault)
					UpdateList(newOptions, newDefault)
				end,
			}
		end

		return Elements
	end

	return WindowHandler
end

return Library
