		waitingForKey = true
		keyButton.Text = "..."

		Tween(keyButton, 0.15, {
			TextColor3 = Theme.Accent,
			BackgroundColor3 = Theme.AccentSoft,
		})
	end)

	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if UserInputService:GetFocusedTextBox() then
			return
		end

		if waitingForKey then
			if input.UserInputType == Enum.UserInputType.Keyboard then
				if input.KeyCode == Enum.KeyCode.Escape then
					waitingForKey = false
					keyButton.Text = toggleKey.Name
					return
				end

				if input.KeyCode ~= Enum.KeyCode.Unknown then
					toggleKey = input.KeyCode
					waitingForKey = false
					keyButton.Text = toggleKey.Name
					return
				end
			end

			return
		end

		if gameProcessed then
			return
		end

		if input.KeyCode == toggleKey then
			SetVisible(not visible)
		end
	end)

	--// Dragging
	do
		local dragging = false
		local dragStart
		local startPosition

		topbar.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
				return
			end

			if input.Position.X > topbar.AbsolutePosition.X + topbar.AbsoluteSize.X - 160 then
				return
			end

			dragging = true
			dragStart = input.Position
			startPosition = windowRoot.Position
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if not dragging then
				return
			end

			if input.UserInputType ~= Enum.UserInputType.MouseMovement then
				return
			end

			local delta = input.Position - dragStart

			windowRoot.Position = UDim2.new(
				startPosition.X.Scale,
				startPosition.X.Offset + delta.X,
				startPosition.Y.Scale,
				startPosition.Y.Offset + delta.Y
			)
		end)
	end

	if startupSound.Toggle and startupSound.SoundID then
		task.spawn(function()
			local soundId = tostring(startupSound.SoundID)

			if not soundId:find("rbxassetid://") then
				soundId = "rbxassetid://" .. soundId
			end

			local sound = Create("Sound", {
				Name = "Startup Sound",
				SoundId = soundId,
				Volume = startupSound.Volume or 1,
				TimePosition = startupSound.TimePosition or 0,
				Parent = SoundService,
			})

			sound:Play()
			sound.Ended:Wait()
			sound:Destroy()
		end)
	end

