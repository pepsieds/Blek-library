--// dark_UI Library Rewrite
--// Added:
--// - Fixed back shadow
--// - Toggle key button can be clicked to rebind
--// - Dropdown:UpdateList(newTable, newDefault)
--// - Single dropdown + multi dropdown support
--// - Cleaner internals / safer callbacks

local Library = {}

--// Services
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local CoreGui = game:GetService("CoreGui")
local SoundService = game:GetService("SoundService")

local LocalPlayer = Players.LocalPlayer

--// Theme
local Theme = {
	Main = Color3.fromRGB(25, 25, 25),
	Topbar = Color3.fromRGB(30, 30, 30),
	Container = Color3.fromRGB(32, 32, 32),

	Element = Color3.fromRGB(38, 38, 38),
	ElementHover = Color3.fromRGB(44, 44, 44),
	ElementDown = Color3.fromRGB(50, 50, 50),

	Text = Color3.fromRGB(210, 210, 210),
	SubText = Color3.fromRGB(150, 150, 150),

	Accent = Color3.fromRGB(32, 202, 106),
	AccentDark = Color3.fromRGB(23, 143, 75),

	Stroke = Color3.fromRGB(55, 55, 55),
	Scroll = Color3.fromRGB(80, 80, 80),
}

--// Utility
local function Create(className, props, children)
	local object = Instance.new(className)

	for prop, value in pairs(props or {}) do
		object[prop] = value
	end

	for _, child in ipairs(children or {}) do
		child.Parent = object
	end

	return object
end

local function Corner(radius)
	return Create("UICorner", {
		CornerRadius = UDim.new(0, radius or 6)
	})
end

local function Stroke(color, thickness, transparency)
	return Create("UIStroke", {
		Color = color or Theme.Stroke,
		Thickness = thickness or 1,
		Transparency = transparency or 0
	})
end

local function Tween(object, time, props)
	local tween = TweenService:Create(
		object,
		TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		props
	)

	tween:Play()
	return tween
end

local function SafeCallback(callback, ...)
	if typeof(callback) ~= "function" then
		return
	end

	local success, err = pcall(callback, ...)
	if not success then
		warn("[dark_UI callback error]:", err)
	end
end

local function GetParent()
	local success = pcall(function()
		local test = Instance.new("Folder")
		test.Name = "dark_UI_Test"
		test.Parent = CoreGui
		test:Destroy()
	end)

	if success then
		return CoreGui
	end

	return LocalPlayer:WaitForChild("PlayerGui")
end

local function DestroyOldUI()
	pcall(function()
		for _, v in ipairs(CoreGui:GetChildren()) do
			if v.Name == "dark_UI" then
				v:Destroy()
			end
		end
	end)

	pcall(function()
		local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui")
		if playerGui then
			for _, v in ipairs(playerGui:GetChildren()) do
				if v.Name == "dark_UI" then
					v:Destroy()
				end
			end
		end
	end)
end

function Library:Create(config)
	config = config or {}

	DestroyOldUI()

	local windowName = config.Name or "dark_UI"
	local toggleKey = config.ToggleKey or Enum.KeyCode.RightShift
	local startupSound = config.StartupSound or {}

	local UIParent = GetParent()

	local dark_UI = Create("ScreenGui", {
		Name = "dark_UI",
		ResetOnSpawn = false,
		ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
		DisplayOrder = 999999,
		Parent = UIParent,
	})

	--// Window root fixes shadow desync.
	--// Shadow and main are both children of this frame, so dragging only moves one object.
	local windowRoot = Create("Frame", {
		Name = "windowRoot",
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromOffset(488, 299),
		ZIndex = 10,
		Parent = dark_UI,
	})

	local shadow = Create("ImageLabel", {
		Name = "shadow",
		Image = "rbxassetid://1316045217",
		ImageColor3 = Color3.fromRGB(0, 0, 0),
		ImageTransparency = 0.42,
		ScaleType = Enum.ScaleType.Slice,
		SliceCenter = Rect.new(10, 10, 118, 118),
		BackgroundTransparency = 1,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.new(0.5, 0, 0.5, 8),
		Size = UDim2.new(1, 70, 1, 70),
		ZIndex = 9,
		Parent = windowRoot,
	})

	local main = Create("Frame", {
		Name = "main",
		BackgroundColor3 = Theme.Main,
		AnchorPoint = Vector2.new(0.5, 0.5),
		Position = UDim2.fromScale(0.5, 0.5),
		Size = UDim2.fromScale(1, 1),
		ZIndex = 11,
		Parent = windowRoot,
	}, {
		Corner(8),
		Stroke(Color3.fromRGB(45, 45, 45), 1, 0.15),
	})

	local topbar = Create("Frame", {
		Name = "topbar",
		BackgroundColor3 = Theme.Topbar,
		Size = UDim2.new(1, 0, 0, 48),
		ZIndex = 12,
		Parent = main,
	}, {
		Corner(8),
	})

	--// Covers the rounded bottom of topbar so only main has clean rounding.
	Create("Frame", {
		Name = "topbarBottomFix",
		BackgroundColor3 = Theme.Topbar,
		BorderSizePixel = 0,
		Position = UDim2.new(0, 0, 1, -8),
		Size = UDim2.new(1, 0, 0, 8),
		ZIndex = 12,
		Parent = topbar,
	})

	local title = Create("TextLabel", {
		Name = "title",
		Font = Enum.Font.GothamMedium,
		Text = windowName,
		TextColor3 = Theme.Text,
		TextSize = 18,
		TextXAlignment = Enum.TextXAlignment.Left,
		TextYAlignment = Enum.TextYAlignment.Center,
		BackgroundTransparency = 1,
		Position = UDim2.fromOffset(18, 0),
		Size = UDim2.new(1, -155, 1, 0),
		ZIndex = 13,
		Parent = topbar,
	})

	local keyButton = Create("TextButton", {
		Name = "keyButton",
		Font = Enum.Font.GothamMedium,
		Text = toggleKey.Name,
		TextColor3 = Theme.SubText,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Center,
		TextYAlignment = Enum.TextYAlignment.Center,
		AutoButtonColor = false,
		BackgroundColor3 = Color3.fromRGB(36, 36, 36),
		Position = UDim2.new(1, -120, 0.5, -12),
		Size = UDim2.fromOffset(100, 24),
		ZIndex = 13,
		Parent = topbar,
	}, {
		Corner(5),
		Stroke(Color3.fromRGB(50, 50, 50), 1, 0.25),
	})

	local tabContainer = Create("Frame", {
		Name = "tabContainer",
		BackgroundColor3 = Theme.Container,
		Position = UDim2.fromOffset(16, 62),
		Size = UDim2.fromOffset(456, 32),
		ZIndex = 12,
		Parent = main,
	}, {
		Corner(6),
		Create("UIPadding", {
			PaddingLeft = UDim.new(0, 7),
			PaddingRight = UDim.new(0, 7),
			PaddingTop = UDim.new(0, 4),
		}),
		Create("UIListLayout", {
			FillDirection = Enum.FillDirection.Horizontal,
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 8),
		}),
	})

	local pageContainer = Create("Frame", {
		Name = "pageContainer",
		BackgroundColor3 = Theme.Container,
		Position = UDim2.fromOffset(16, 108),
		Size = UDim2.fromOffset(456, 175),
		ZIndex = 12,
		Parent = main,
	}, {
		Corner(6),
	})

	local tabs = {}
	local selectedTab = nil
	local visible = true
	local waitingForKey = false

	local function SetVisible(state)
		visible = state
		windowRoot.Visible = state
	end

	local function SelectTab(tabData)
		selectedTab = tabData

		for _, data in ipairs(tabs) do
			data.Page.Visible = false

			Tween(data.Button, 0.18, {
				TextTransparency = 0.45,
				TextColor3 = Theme.SubText,
			})
		end

		tabData.Page.Visible = true

		Tween(tabData.Button, 0.18, {
			TextTransparency = 0,
			TextColor3 = Theme.Text,
		})
	end

	--// Toggle keybind button
	keyButton.MouseEnter:Connect(function()
		Tween(keyButton, 0.15, {
			BackgroundColor3 = Color3.fromRGB(42, 42, 42),
			TextColor3 = Theme.Text,
		})
	end)

	keyButton.MouseLeave:Connect(function()
		Tween(keyButton, 0.15, {
			BackgroundColor3 = Color3.fromRGB(36, 36, 36),
			TextColor3 = Theme.SubText,
		})
	end)

	keyButton.MouseButton1Click:Connect(function()
		waitingForKey = true
		keyButton.Text = "..."
		Tween(keyButton, 0.15, {
			TextColor3 = Theme.Accent,
			BackgroundColor3 = Color3.fromRGB(40, 48, 43),
		})
	end)

	--// Toggle UI + keybind rebind
	UserInputService.InputBegan:Connect(function(input, gameProcessed)
		if UserInputService:GetFocusedTextBox() then
			return
		end

		if waitingForKey then
			if input.UserInputType == Enum.UserInputType.Keyboard then
				if input.KeyCode == Enum.KeyCode.Escape then
					waitingForKey = false
					keyButton.Text = toggleKey.Name

					Tween(keyButton, 0.15, {
						TextColor3 = Theme.SubText,
						BackgroundColor3 = Color3.fromRGB(36, 36, 36),
					})

					return
				end

				if input.KeyCode ~= Enum.KeyCode.Unknown then
					toggleKey = input.KeyCode
					waitingForKey = false
					keyButton.Text = toggleKey.Name

					Tween(keyButton, 0.15, {
						TextColor3 = Theme.SubText,
						BackgroundColor3 = Color3.fromRGB(36, 36, 36),
					})

					return
				end
			end

			return
		end

		if gameProcessed then
			return
		end

		if input.KeyCode == toggleKey then
			SetVisible(not visible)
		end
	end)

	--// Dragging
	do
		local dragging = false
		local dragStart
		local startPosition

		topbar.InputBegan:Connect(function(input)
			if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
				return
			end

			dragging = true
			dragStart = input.Position
			startPosition = windowRoot.Position
		end)

		UserInputService.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = false
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if not dragging then
				return
			end

			if input.UserInputType ~= Enum.UserInputType.MouseMovement then
				return
			end

			local delta = input.Position - dragStart

			local newPosition = UDim2.new(
				startPosition.X.Scale,
				startPosition.X.Offset + delta.X,
				startPosition.Y.Scale,
				startPosition.Y.Offset + delta.Y
			)

			windowRoot.Position = newPosition
		end)
	end

	--// Startup sound
	if startupSound.Toggle and startupSound.SoundID then
		task.spawn(function()
			local soundId = tostring(startupSound.SoundID)

			if not soundId:find("rbxassetid://") then
				soundId = "rbxassetid://" .. soundId
			end

			local sound = Create("Sound", {
				Name = "Startup Sound",
				SoundId = soundId,
				Volume = startupSound.Volume or 1,
				TimePosition = startupSound.TimePosition or 0,
				Parent = SoundService,
			})

			sound:Play()
			sound.Ended:Wait()
			sound:Destroy()
		end)
	end

	local WindowHandler = {}

	function WindowHandler:Exit()
		dark_UI:Destroy()
	end

	function WindowHandler:SetVisible(state)
		SetVisible(state)
	end

	function WindowHandler:Toggle()
		SetVisible(not visible)
	end

	function WindowHandler:SetToggleKey(keyCode)
		if typeof(keyCode) == "EnumItem" and keyCode.EnumType == Enum.KeyCode then
			toggleKey = keyCode
			keyButton.Text = toggleKey.Name
		end
	end

	function WindowHandler:GetToggleKey()
		return toggleKey
	end

	function WindowHandler:Tab(tabName)
		tabName = tostring(tabName or "Tab")

		local tabButton = Create("TextButton", {
			Name = tabName,
			Font = Enum.Font.GothamMedium,
			Text = tabName,
			TextColor3 = Theme.SubText,
			TextSize = 13,
			TextTransparency = 0.45,
			TextXAlignment = Enum.TextXAlignment.Center,
			AutomaticSize = Enum.AutomaticSize.X,
			BackgroundTransparency = 1,
			Size = UDim2.fromOffset(10, 24),
			AutoButtonColor = false,
			ZIndex = 13,
			Parent = tabContainer,
		})

		local page = Create("Frame", {
			Name = tabName .. "_Page",
			BackgroundTransparency = 1,
			Size = UDim2.fromScale(1, 1),
			Visible = false,
			ZIndex = 13,
			Parent = pageContainer,
		})

		local holder = Create("ScrollingFrame", {
			Name = "holder",
			Active = true,
			BackgroundTransparency = 1,
			BorderSizePixel = 0,
			ScrollBarThickness = 2,
			ScrollBarImageColor3 = Theme.Scroll,
			ScrollingDirection = Enum.ScrollingDirection.Y,
			CanvasSize = UDim2.fromOffset(0, 0),
			Size = UDim2.fromScale(1, 1),
			ZIndex = 14,
			Parent = page,
		})

		Create("UIPadding", {
			PaddingLeft = UDim.new(0, 7),
			PaddingRight = UDim.new(0, 7),
			PaddingTop = UDim.new(0, 8),
			PaddingBottom = UDim.new(0, 8),
			Parent = holder,
		})

		local layout = Create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 5),
			Parent = holder,
		})

		layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			holder.CanvasSize = UDim2.fromOffset(0, layout.AbsoluteContentSize.Y + 18)
		end)

		local tabData = {
			Button = tabButton,
			Page = page,
		}

		table.insert(tabs, tabData)

		tabButton.MouseButton1Click:Connect(function()
			SelectTab(tabData)
		end)

		if not selectedTab then
			SelectTab(tabData)
		end

		local Elements = {}

		local function BaseElement(className, height)
			return Create(className or "TextButton", {
				BackgroundColor3 = Theme.Element,
				Size = UDim2.new(1, -14, 0, height or 32),
				Text = "",
				AutoButtonColor = false,
				ZIndex = 15,
				Parent = holder,
			}, {
				Corner(6),
			})
		end

		function Elements:Label(text)
			local label = Create("Frame", {
				Name = "label",
				BackgroundColor3 = Color3.fromRGB(30, 30, 30),
				BackgroundTransparency = 0.25,
				Size = UDim2.new(1, -14, 0, 26),
				ZIndex = 15,
				Parent = holder,
			}, {
				Corner(5),
				Stroke(Color3.fromRGB(48, 48, 48), 1, 0.45),
			})

			Create("Frame", {
				Name = "accentLine",
				BackgroundColor3 = Theme.Accent,
				Position = UDim2.fromOffset(8, 7),
				Size = UDim2.fromOffset(2, 12),
				ZIndex = 16,
				Parent = label,
			}, {
				Corner(2),
			})

			local textLabel = Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text or "Label"),
				TextColor3 = Theme.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				TextTruncate = Enum.TextTruncate.AtEnd,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(18, 0),
				Size = UDim2.new(1, -26, 1, 0),
				ZIndex = 16,
				Parent = label,
			})

			return {
				Instance = label,

				Set = function(_, newText)
					textLabel.Text = tostring(newText)
				end,
			}
		end

		function Elements:Button(text, callback)
			local button = BaseElement("TextButton", 32)

			Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text or "Button"),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -45, 1, 0),
				ZIndex = 16,
				Parent = button,
			})

			Create("ImageLabel", {
				Name = "icon",
				Image = "rbxassetid://9584292194",
				ImageColor3 = Theme.SubText,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -28, 0.5, -9),
				Size = UDim2.fromOffset(18, 18),
				ZIndex = 16,
				Parent = button,
			})

			button.MouseEnter:Connect(function()
				Tween(button, 0.18, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			button.MouseLeave:Connect(function()
				Tween(button, 0.18, {
					BackgroundColor3 = Theme.Element
				})
			end)

			button.MouseButton1Down:Connect(function()
				Tween(button, 0.1, {
					BackgroundColor3 = Theme.ElementDown
				})
			end)

			button.MouseButton1Up:Connect(function()
				Tween(button, 0.14, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			button.MouseButton1Click:Connect(function()
				SafeCallback(callback)
			end)

			return button
		end

		function Elements:Toggle(text, default, callback)
			if typeof(default) == "function" then
				callback = default
				default = false
			end

			local toggled = default == true

			local toggle = BaseElement("TextButton", 32)

			Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text or "Toggle"),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -60, 1, 0),
				ZIndex = 16,
				Parent = toggle,
			})

			local box = Create("Frame", {
				Name = "box",
				BackgroundColor3 = Color3.fromRGB(45, 45, 45),
				Position = UDim2.new(1, -29, 0.5, -9),
				Size = UDim2.fromOffset(18, 18),
				ZIndex = 16,
				Parent = toggle,
			}, {
				Corner(4),
				Stroke(Color3.fromRGB(76, 76, 76), 1, 0),
			})

			local boxStroke = box:FindFirstChildOfClass("UIStroke")

			local function Update(state, fireCallback)
				toggled = state == true

				Tween(box, 0.18, {
					BackgroundColor3 = toggled and Theme.AccentDark or Color3.fromRGB(45, 45, 45),
				})

				Tween(boxStroke, 0.18, {
					Color = toggled and Theme.Accent or Color3.fromRGB(76, 76, 76),
				})

				if fireCallback then
					SafeCallback(callback, toggled)
				end
			end

			toggle.MouseEnter:Connect(function()
				Tween(toggle, 0.18, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			toggle.MouseLeave:Connect(function()
				Tween(toggle, 0.18, {
					BackgroundColor3 = Theme.Element
				})
			end)

			toggle.MouseButton1Click:Connect(function()
				Update(not toggled, true)
			end)

			Update(toggled, false)

			return {
				Instance = toggle,

				Set = function(_, state)
					Update(state == true, true)
				end,

				Get = function()
					return toggled
				end,
			}
		end

		function Elements:Slider(text, default, min, max, callback)
			text = text or "Slider"
			min = tonumber(min) or 0
			max = tonumber(max) or 100
			default = tonumber(default) or min

			default = math.clamp(default, min, max)

			local value = default
			local dragging = false

			local slider = BaseElement("TextButton", 32)

			Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -190, 1, 0),
				ZIndex = 16,
				Parent = slider,
			})

			local valueLabel = Create("TextLabel", {
				Name = "value",
				Font = Enum.Font.Gotham,
				Text = tostring(value),
				TextColor3 = Theme.SubText,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Right,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -174, 0, 0),
				Size = UDim2.fromOffset(48, 32),
				ZIndex = 16,
				Parent = slider,
			})

			local track = Create("Frame", {
				Name = "track",
				BackgroundColor3 = Color3.fromRGB(27, 27, 27),
				Position = UDim2.new(1, -116, 0.5, -4),
				Size = UDim2.fromOffset(102, 8),
				ZIndex = 16,
				Parent = slider,
			}, {
				Corner(4),
			})

			local fill = Create("Frame", {
				Name = "fill",
				BackgroundColor3 = Theme.AccentDark,
				Size = UDim2.fromScale(0, 1),
				ZIndex = 17,
				Parent = track,
			}, {
				Corner(4),
			})

			local function SetValue(newValue, fireCallback)
				newValue = math.clamp(math.floor(newValue), min, max)

				value = newValue
				valueLabel.Text = tostring(value)

				local percent = 0
				if max ~= min then
					percent = (value - min) / (max - min)
				end

				Tween(fill, 0.08, {
					Size = UDim2.fromScale(percent, 1)
				})

				if fireCallback then
					SafeCallback(callback, value)
				end
			end

			local function UpdateFromMouse()
				local mouseX = UserInputService:GetMouseLocation().X

				local percent = math.clamp(
					(mouseX - track.AbsolutePosition.X) / track.AbsoluteSize.X,
					0,
					1
				)

				SetValue(min + ((max - min) * percent), true)
			end

			slider.MouseEnter:Connect(function()
				Tween(slider, 0.18, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			slider.MouseLeave:Connect(function()
				if not dragging then
					Tween(slider, 0.18, {
						BackgroundColor3 = Theme.Element
					})
				end
			end)

			slider.MouseButton1Down:Connect(function()
				dragging = true

				Tween(slider, 0.1, {
					BackgroundColor3 = Theme.ElementDown
				})

				UpdateFromMouse()
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false

					Tween(slider, 0.18, {
						BackgroundColor3 = Theme.Element
					})
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if not dragging then
					return
				end

				if input.UserInputType == Enum.UserInputType.MouseMovement then
					UpdateFromMouse()
				end
			end)

			SetValue(default, false)

			return {
				Instance = slider,

				Set = function(_, newValue)
					SetValue(newValue, true)
				end,

				Get = function()
					return value
				end,
			}
		end

		function Elements:Textbox(text, callback)
			local textboxFrame = BaseElement("Frame", 32)

			Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text or "Textbox"),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -130, 1, 0),
				ZIndex = 16,
				Parent = textboxFrame,
			})

			local textBox = Create("TextBox", {
				Name = "input",
				Font = Enum.Font.Gotham,
				Text = "",
				PlaceholderText = "...",
				PlaceholderColor3 = Color3.fromRGB(110, 110, 110),
				TextColor3 = Theme.Text,
				TextSize = 12,
				ClearTextOnFocus = false,
				BackgroundColor3 = Theme.Container,
				Position = UDim2.new(1, -96, 0.5, -10),
				Size = UDim2.fromOffset(82, 20),
				ZIndex = 16,
				Parent = textboxFrame,
			}, {
				Corner(5),
			})

			textboxFrame.MouseEnter:Connect(function()
				Tween(textboxFrame, 0.18, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			textboxFrame.MouseLeave:Connect(function()
				Tween(textboxFrame, 0.18, {
					BackgroundColor3 = Theme.Element
				})
			end)

			textBox.FocusLost:Connect(function(enterPressed)
				SafeCallback(callback, textBox.Text, enterPressed)
			end)

			return textBox
		end

		function Elements:Dropdown(text, options, default, callback)
			text = text or "Dropdown"
			options = options or {}

			--// Supported:
			--// Dropdown("Mode", {"A", "B"}, "A", callback)
			--// Dropdown("Modes", {"A", "B"}, {"A"}, callback)
			--// Dropdown("Modes", {
			--//     Options = {"A", "B", "C"},
			--//     Default = {"A", "C"},
			--//     Multi = true,
			--//     Callback = function(selected) end
			--// })

			local multiSelect = false

			if typeof(options) == "table" and options.Options then
				local dropConfig = options

				options = dropConfig.Options or {}
				default = dropConfig.Default
				callback = dropConfig.Callback
				multiSelect = dropConfig.Multi == true
			else
				multiSelect = typeof(default) == "table"

				if typeof(default) == "function" then
					callback = default
					default = nil
					multiSelect = false
				end
			end

			local opened = false
			local optionButtons = {}
			local selected

			if multiSelect then
				selected = {}

				if typeof(default) == "table" then
					for _, value in ipairs(default) do
						selected[value] = true
					end
				end
			else
				selected = default or options[1] or "None"
			end

			local dropdown = BaseElement("TextButton", 32)
			dropdown.ClipsDescendants = true

			Create("TextLabel", {
				Name = "text",
				Font = Enum.Font.Gotham,
				Text = tostring(text),
				TextColor3 = Theme.Text,
				TextSize = 13,
				TextXAlignment = Enum.TextXAlignment.Left,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(10, 0),
				Size = UDim2.new(1, -170, 0, 32),
				ZIndex = 16,
				Parent = dropdown,
			})

			local selectedLabel = Create("TextLabel", {
				Name = "selected",
				Font = Enum.Font.Gotham,
				Text = "",
				TextColor3 = Theme.SubText,
				TextSize = 12,
				TextXAlignment = Enum.TextXAlignment.Right,
				TextYAlignment = Enum.TextYAlignment.Center,
				TextTruncate = Enum.TextTruncate.AtEnd,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -165, 0, 0),
				Size = UDim2.fromOffset(130, 32),
				ZIndex = 16,
				Parent = dropdown,
			})

			local arrow = Create("TextLabel", {
				Name = "arrow",
				Font = Enum.Font.GothamBold,
				Text = "⌄",
				TextColor3 = Theme.SubText,
				TextSize = 16,
				TextXAlignment = Enum.TextXAlignment.Center,
				TextYAlignment = Enum.TextYAlignment.Center,
				BackgroundTransparency = 1,
				Position = UDim2.new(1, -30, 0, 0),
				Size = UDim2.fromOffset(20, 32),
				ZIndex = 16,
				Parent = dropdown,
			})

			local optionHolder = Create("Frame", {
				Name = "optionHolder",
				BackgroundTransparency = 1,
				Position = UDim2.fromOffset(7, 34),
				Size = UDim2.new(1, -14, 0, 0),
				ZIndex = 17,
				Parent = dropdown,
			}, {
				Create("UIListLayout", {
					SortOrder = Enum.SortOrder.LayoutOrder,
					Padding = UDim.new(0, 4),
				})
			})

			local function OptionExists(option)
				for _, existing in ipairs(options) do
					if existing == option then
						return true
					end
				end

				return false
			end

			local function GetSelectedArray()
				local list = {}

				for _, option in ipairs(options) do
					if selected[option] then
						table.insert(list, option)
					end
				end

				return list
			end

			local function UpdateSelectedLabel()
				if multiSelect then
					local list = GetSelectedArray()

					if #list == 0 then
						selectedLabel.Text = "None"
					elseif #list == 1 then
						selectedLabel.Text = tostring(list[1])
					else
						selectedLabel.Text = tostring(#list) .. " selected"
					end
				else
					selectedLabel.Text = tostring(selected)
				end
			end

			local function GetOpenHeight()
				local count = #optionButtons
				local optionHeight = count * 26
				local paddingHeight = math.max(count - 1, 0) * 4

				return 38 + optionHeight + paddingHeight
			end

			local function SetOpen(state)
				opened = state == true

				Tween(dropdown, 0.18, {
					Size = opened and UDim2.new(1, -14, 0, GetOpenHeight()) or UDim2.new(1, -14, 0, 32)
				})

				Tween(arrow, 0.18, {
					Rotation = opened and 180 or 0
				})
			end

			local function FireCallback()
				if multiSelect then
					SafeCallback(callback, GetSelectedArray())
				else
					SafeCallback(callback, selected)
				end
			end

			local function UpdateOptionVisual(optionButton, option)
				local check = optionButton:FindFirstChild("check")
				local optionText = optionButton:FindFirstChild("text")

				local isSelected

				if multiSelect then
					isSelected = selected[option] == true
				else
					isSelected = selected == option
				end

				if check then
					check.Visible = isSelected
				end

				if optionText then
					optionText.TextColor3 = isSelected and Theme.Text or Theme.SubText
				end

				Tween(optionButton, 0.14, {
					BackgroundColor3 = isSelected and Color3.fromRGB(42, 42, 42) or Color3.fromRGB(34, 34, 34)
				})
			end

			local function RefreshVisuals()
				for _, data in ipairs(optionButtons) do
					UpdateOptionVisual(data.Button, data.Option)
				end

				UpdateSelectedLabel()
			end

			local function SetSelected(value, fireCallback)
				if multiSelect then
					if typeof(value) == "table" then
						table.clear(selected)

						for _, item in ipairs(value) do
							if OptionExists(item) then
								selected[item] = true
							end
						end
					else
						if OptionExists(value) then
							selected[value] = not selected[value]
						end
					end
				else
					if OptionExists(value) then
						selected = value
					else
						selected = options[1] or "None"
					end

					SetOpen(false)
				end

				RefreshVisuals()

				if fireCallback then
					FireCallback()
				end
			end

			local function ClearOptions()
				for _, data in ipairs(optionButtons) do
					data.Button:Destroy()
				end

				table.clear(optionButtons)
			end

			local function AddOption(option)
				local optionButton = Create("TextButton", {
					Name = tostring(option),
					BackgroundColor3 = Color3.fromRGB(34, 34, 34),
					Text = "",
					AutoButtonColor = false,
					Size = UDim2.new(1, 0, 0, 26),
					ZIndex = 18,
					Parent = optionHolder,
				}, {
					Corner(5),
				})

				Create("TextLabel", {
					Name = "check",
					Font = Enum.Font.GothamBold,
					Text = "✓",
					TextColor3 = Theme.Accent,
					TextSize = 13,
					TextXAlignment = Enum.TextXAlignment.Center,
					TextYAlignment = Enum.TextYAlignment.Center,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(6, 0),
					Size = UDim2.fromOffset(18, 26),
					Visible = false,
					ZIndex = 19,
					Parent = optionButton,
				})

				Create("TextLabel", {
					Name = "text",
					Font = Enum.Font.Gotham,
					Text = tostring(option),
					TextColor3 = Theme.SubText,
					TextSize = 12,
					TextXAlignment = Enum.TextXAlignment.Left,
					TextYAlignment = Enum.TextYAlignment.Center,
					BackgroundTransparency = 1,
					Position = UDim2.fromOffset(28, 0),
					Size = UDim2.new(1, -36, 1, 0),
					ZIndex = 19,
					Parent = optionButton,
				})

				optionButton.MouseEnter:Connect(function()
					Tween(optionButton, 0.14, {
						BackgroundColor3 = Theme.ElementHover
					})
				end)

				optionButton.MouseLeave:Connect(function()
					UpdateOptionVisual(optionButton, option)
				end)

				optionButton.MouseButton1Click:Connect(function()
					SetSelected(option, true)
				end)

				table.insert(optionButtons, {
					Button = optionButton,
					Option = option,
				})

				UpdateOptionVisual(optionButton, option)
			end

			local function UpdateList(newOptions, newDefault)
				options = newOptions or {}

				ClearOptions()

				if multiSelect then
					local oldSelected = selected
					selected = {}

					if typeof(newDefault) == "table" then
						for _, item in ipairs(newDefault) do
							if OptionExists(item) then
								selected[item] = true
							end
						end
					else
						for _, option in ipairs(options) do
							if oldSelected[option] then
								selected[option] = true
							end
						end
					end
				else
					if newDefault ~= nil and OptionExists(newDefault) then
						selected = newDefault
					elseif OptionExists(selected) then
						selected = selected
					else
						selected = options[1] or "None"
					end
				end

				for _, option in ipairs(options) do
					AddOption(option)
				end

				RefreshVisuals()
				SetOpen(false)
			end

			for _, option in ipairs(options) do
				AddOption(option)
			end

			dropdown.MouseEnter:Connect(function()
				Tween(dropdown, 0.18, {
					BackgroundColor3 = Theme.ElementHover
				})
			end)

			dropdown.MouseLeave:Connect(function()
				Tween(dropdown, 0.18, {
					BackgroundColor3 = Theme.Element
				})
			end)

			dropdown.InputBegan:Connect(function(input)
				if input.UserInputType ~= Enum.UserInputType.MouseButton1 then
					return
				end

				local mouseY = UserInputService:GetMouseLocation().Y
				local relativeY = mouseY - dropdown.AbsolutePosition.Y

				if relativeY <= 32 then
					SetOpen(not opened)
				end
			end)

			RefreshVisuals()

			return {
				Instance = dropdown,

				Set = function(_, value)
					SetSelected(value, true)
				end,

				Get = function()
					if multiSelect then
						return GetSelectedArray()
					end

					return selected
				end,

				Open = function()
					SetOpen(true)
				end,

				Close = function()
					SetOpen(false)
				end,

				Refresh = function(_, newOptions, newDefault)
					UpdateList(newOptions, newDefault)
				end,

				UpdateList = function(_, newOptions, newDefault)
					UpdateList(newOptions, newDefault)
				end,
			}
		end

		return Elements
	end

	return WindowHandler
end

return Library
